	email = mccolgand@googlemail.com
	signingkey = 

[core]
	editor = nvim
	autocrlf = input
	whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
	excludesfile = ~/.gitignore_global
	pager = less -FRX

[init]
	defaultBranch = main

[color]
	ui = auto
	branch = auto
	diff = auto
	status = auto

[color "branch"]
	current = yellow bold
	local = green bold
	remote = cyan bold

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse

[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold

[alias]
	# Shortcuts
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	df = diff
	lg = log --oneline --graph --decorate --all
	ll = log --pretty=format:"%C(yellow)%h%Creset %s %C(cyan)(%cr)%Creset %C(bold blue)<%an>%Creset" --graph --all
	last = log -1 HEAD --stat
	unstage = reset HEAD --
	undo = reset --soft HEAD~1
	aliases = config --get-regexp '^alias\\.'

	# Branch management
	bd = branch -d
	bD = branch -D
	branches = branch -a
	remotes = remote -v

	# Stash
	sl = stash list
	sa = stash apply
	ss = stash save

	# Working with remotes
	sync = !git fetch --all && git pull --rebase

	# Find
	find = log --all --full-history --

[diff]
	tool = vimdiff
	colorMoved = zebra
	algorithm = patience
	renames = copies

[difftool]
	prompt = false

[merge]
	tool = vimdiff
	conflictstyle = diff3
	log = true
	ff = false

[mergetool]
	prompt = false
	keepBackup = false

[push]
	default = current
	followTags = true
	autoSetupRemote = true

[pull]
	rebase = true

[fetch]
	prune = true
	prunetags = true

[rebase]
	autosquash = true
	autostash = true

[commit]
	gpgsign = false
	verbose = true

[tag]
	sort = version:refname

[log]
	date = relative
	abbrevCommit = true

[status]
	showUntrackedFiles = all
	submoduleSummary = true

[branch]
	sort = -committerdate
	autosetuprebase = always

[help]
	autocorrect = 1

[rerere]
	enabled = true

[credential]
	helper = osxkeychain

[url "git@github.com:"]
	insteadOf = https://github.com/

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
